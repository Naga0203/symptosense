# Django
DJANGO_SECRET_KEY=your-secret-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# OpenRouter (legacy single-key)
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_MODEL=google/gemma-3-27b-it

# Firebase
FIREBASE_CREDENTIALS_PATH=/path/to/firebase-credentials.json
FIREBASE_STORAGE_BUCKET=your-bucket.appspot.com

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ─────────────────────────────────────────────────────────────
# AI AGENT CONFIGURATION (4 Agents × Different Keys & Models)
# Each agent uses its own OpenRouter API key and model.
# ─────────────────────────────────────────────────────────────

# Agent 1: Recommendation Agent
RECOMMENDATION_AGENT_API_KEY=sk-or-v1-your-recommendation-key
RECOMMENDATION_AGENT_MODEL=google/gemma-3-27b-it

# Agent 2: Treatment Exploration Agent
TREATMENT_AGENT_API_KEY=sk-or-v1-your-treatment-key
TREATMENT_AGENT_MODEL=openai/gpt-4.1-nano

# Agent 3: Clinical Guidelines Agent
CLINICAL_GUIDELINES_AGENT_API_KEY=sk-or-v1-your-clinical-key
CLINICAL_GUIDELINES_AGENT_MODEL=meta-llama/llama-4-maverick

# Agent 4: Lifestyle & Diet Agent
LIFESTYLE_DIET_AGENT_API_KEY=sk-or-v1-your-lifestyle-key
LIFESTYLE_DIET_AGENT_MODEL=microsoft/phi-4


RECOMMENDATION_AGENT_API_KEY=
RECOMMENDATION_AGENT_MODEL=

# Agent 2: Treatment Exploration Agent
TREATMENT_AGENT_API_KEY=
TREATMENT_AGENT_MODEL=

# Agent 3: Clinical Guidelines Agent
CLINICAL_GUIDELINES_AGENT_API_KEY=####
CLINICAL_GUIDELINES_AGENT_MODEL=

# Agent 4: Lifestyle & Diet Agent
LIFESTYLE_DIET_AGENT_API_KEY####
LIFESTYLE_DIET_AGENT_MODEL=
